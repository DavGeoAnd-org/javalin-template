# otel general
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=test,service.framework=javalin,service.namespace=template
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-service:4318
OTEL_RESOURCE_DISABLED_KEYS=host.arch,os.description,os.type,os.version,process.command_args,process.command_line,process.executable.path,process.pid,process.runtime.description,process.runtime.name
OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4095
OTEL_INSTRUMENTATION_MICROMETER_ENABLED=true
OTEL_RESOURCE_PROVIDERS_AWS_ENABLED=true

# otel metrics
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_METRICS_DEFAULT_HISTOGRAM_AGGREGATION=BASE2_EXPONENTIAL_BUCKET_HISTOGRAM
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=DELTA

# otel logs
OTEL_LOGS_EXPORTER=otlp

# otel traces
OTEL_TRACES_EXPORTER=otlp